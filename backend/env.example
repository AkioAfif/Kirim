# Copy file ini jadi .env lalu isi setelah menjalankan script setup.
# JANGAN commit file .env (isinya secret key) ke git.

# Diisi otomatis oleh script setup-issuer-testusd.ts (Opsi B)
TESTUSD_ISSUER_PUBLIC_KEY=
TESTUSD_ISSUER_SECRET_KEY=
TESTUSD_DISTRIBUTOR_PUBLIC_KEY=
TESTUSD_DISTRIBUTOR_SECRET_KEY=

# Diisi otomatis oleh script setup-usdc-official.ts (Opsi A)
USDC_DEMO_ACCOUNT_PUBLIC_KEY=
USDC_DEMO_ACCOUNT_SECRET_KEY=

# Konstanta jaringan (tidak perlu diubah untuk testnet)
HORIZON_URL=https://horizon-testnet.stellar.org
FRIENDBOT_URL=https://friendbot.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
